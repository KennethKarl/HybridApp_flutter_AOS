# 배포 환경변수 예시 (민감정보 제외)
# GitLab CI/CD Variables에 등록 필요

# ── Android Signing ──
KEYSTORE_FILE=          # Base64 인코딩된 keystore 파일
KEYSTORE_PASSWORD=      # keystore 비밀번호
KEY_ALIAS=              # 키 별칭
KEY_PASSWORD=           # 키 비밀번호

# ── Firebase App Distribution ──
FIREBASE_APP_ID=        # Firebase Android 앱 ID
FIREBASE_TOKEN=         # Firebase CLI 인증 토큰

# ── Play Store ──
PLAY_STORE_JSON_KEY=    # Google Play Console 서비스 계정 JSON 키 (Base64)

# ── Telegram 알림 ──
TELEGRAM_BOT_TOKEN=     # Telegram Bot 토큰
TELEGRAM_CHAT_ID=       # 알림 채널 ID

# ── App Config ──
APP_VERSION_NAME=0.1.0
APP_VERSION_CODE=1
